            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"resultado\": \"APROVADO\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/{{pedidoId}}/callback", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "{{pedidoId}}", "callback"] }
          }
