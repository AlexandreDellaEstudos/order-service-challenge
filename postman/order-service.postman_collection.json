  "item": [
    {
      "name": "1 - Fluxo feliz",
      "item": [
        {
          "name": "Criar pedido",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "try { var j = pm.response.json(); if (j && j.id != null) pm.collectionVariables.set('pedidoId', j.id); } catch (e) {}"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"clienteId\": \"cliente-1\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/pedidos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pedidos"] }
          }
        },
        {
          "name": "Adicionar item - Notebook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"produtoId\": \"notebook\",\n  \"quantidade\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/pedidos/{{pedidoId}}/itens", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pedidos", "{{pedidoId}}", "itens"] }
          }
        },
        {
          "name": "Adicionar item - Mouse",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"produtoId\": \"mouse\",\n  \"quantidade\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/pedidos/{{pedidoId}}/itens", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pedidos", "{{pedidoId}}", "itens"] }
          }
        },
        {
          "name": "Confirmar pedido",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/pedidos/{{pedidoId}}/confirmacao", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pedidos", "{{pedidoId}}", "confirmacao"] }
