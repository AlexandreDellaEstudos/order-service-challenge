          "name": "Status do pagamento",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/payments/{{pedidoId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "{{pedidoId}}"] }
